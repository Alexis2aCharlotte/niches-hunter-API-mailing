# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=xxx

# OpenAI (for AI-generated content)
OPENAI_API_KEY=sk-xxx

# Email (Resend)
RESEND_API_KEY=xxx

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=xxx
